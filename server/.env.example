# Servidor
PORT=4000
NODE_ENV=development

# Base de datos de la plataforma (MySQL/MariaDB)
# Local XAMPP: puerto 3307 | Hostinger: datos del hPanel
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=
DB_NAME=bi_techcol

# Clave de cifrado de credenciales de conectores (32 bytes en hex = 64 caracteres)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# CORS: origen del frontend en desarrollo
CLIENT_ORIGIN=http://localhost:5173

# Copiloto de IA (Groq - gratis, modelos open-source como Llama 3.3)
# Crea tu clave gratuita en https://console.groq.com/keys
GROQ_API_KEY=
